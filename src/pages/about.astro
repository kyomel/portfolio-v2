---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { profile, siteMeta } from '../data/portfolio';

const title = `About | ${profile.name}`;
---

<BaseLayout title={title} description={siteMeta.description}>
  <SiteHeader currentPath={Astro.url.pathname} />

  <main class="page-main">
    <section class="section card terminal-section" aria-labelledby="about-heading">
      <p class="kicker">Profile module</p>
      <h1 id="about-heading" class="page-title">About</h1>
      <figure class="about-profile" aria-label="Profile image">
        <img class="about-profile__image" src="/images.png" alt={profile.name} loading="eager" fetchpriority="high" />
      </figure>
      {profile.summary.map((paragraph) => <p class="muted">{paragraph}</p>)}
      <p><strong>Birthday:</strong> {profile.birthday}</p>
      <div class="skills" aria-label="Skills">
        {profile.skills.map((skill) => <span class="chip">{skill}</span>)}
      </div>
    </section>
  </main>

  <SiteFooter name={profile.name} />
</BaseLayout>
