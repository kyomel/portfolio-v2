---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SocialIcon from '../components/SocialIcon.astro';
import { profile, siteMeta, socials } from '../data/portfolio';

const title = `Contact | ${profile.name}`;
---

<BaseLayout title={title} description={siteMeta.description}>
  <SiteHeader currentPath={Astro.url.pathname} />

  <main class="page-main">
    <section class="section card terminal-section" aria-labelledby="contact-heading">
      <p class="kicker">Network module</p>
      <h1 id="contact-heading" class="page-title">Contact</h1>
      <p class="muted">Let's connect for collaboration, product ideas, or engineering opportunities.</p>
      <a class="contact-mail" href={`mailto:${profile.email}`} aria-label={`Send an email to ${profile.email}`}>
        <span class="contact-mail__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false">
            <path fill="currentColor" d="M3 6.75A2.75 2.75 0 0 1 5.75 4h12.5A2.75 2.75 0 0 1 21 6.75v10.5A2.75 2.75 0 0 1 18.25 20H5.75A2.75 2.75 0 0 1 3 17.25zm2.75-1.25a1.25 1.25 0 0 0-.78.27L12 11.3l7.03-5.53a1.25 1.25 0 0 0-.78-.27zm13.75 1.9-6.58 5.17a1.5 1.5 0 0 1-1.84 0L4.5 7.4v9.85c0 .69.56 1.25 1.25 1.25h12.5c.69 0 1.25-.56 1.25-1.25z"></path>
          </svg>
        </span>
        <span>{profile.email}</span>
      </a>
      <div class="socials" aria-label="Social profiles">
        {socials.map((social, index) => (
          <a
            class="contact-link"
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${social.label} profile (opens in new tab)`}
            style={`--contact-accent: ${social.color}; --delay: ${index * 90}ms;`}
          >
            <span class="contact-link__icon" aria-hidden="true"><SocialIcon label={social.label} /></span>
            <span class="contact-link__text">{social.label}</span>
            <span class="contact-link__hint">Open profile</span>
          </a>
        ))}
      </div>
    </section>
  </main>

  <SiteFooter name={profile.name} />
</BaseLayout>
