  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "jsx": "preserve",
    "types": [
      "astro/client"
    ]
  },
  "include": [
